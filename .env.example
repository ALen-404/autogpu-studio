# ==================== 数据库 ====================
# 本地开发模式：docker-compose.yml 将 MySQL 映射到宿主机的 13306 端口
# Docker 容器模式：docker-compose.yml 会自动覆盖此配置
DATABASE_URL="mysql://root:autogpu123@localhost:13306/autogpu_studio"

# ==================== 存储 ====================
# minio: S3 兼容对象存储（默认）
# local: 本地文件存储（仅开发调试）
# cos: 预留 provider（当前版本未实现）
STORAGE_TYPE=minio

# MinIO / S3 兼容存储配置
# 本地开发模式：docker-compose.yml 将 MinIO 映射到宿主机的 19000 端口
MINIO_ENDPOINT=http://localhost:19000
MINIO_REGION=us-east-1
MINIO_BUCKET=autogpu-studio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true

# COS 配置（预留）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=

# ==================== 认证 ====================
# 本地开发模式（方式三）：使用 http://localhost:3000
# Docker 容器模式（方式一、二）：由 docker-compose.yml 注入为 http://localhost:13000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=please-change-this-to-a-random-string

# ==================== 应用内部自调用地址 ====================
# 仅用于服务端内部 fetch 本应用 API / 文件。
# 本地开发模式通常与 NEXTAUTH_URL 一致；Docker 模式由 docker-compose.yml 注入为 http://127.0.0.1:3000
INTERNAL_APP_URL=http://127.0.0.1:3000

# ==================== 内部密钥 ====================
CRON_SECRET=please-change-this-cron-secret
INTERNAL_TASK_TOKEN=please-change-this-task-token
API_ENCRYPTION_KEY=autogpu-studio-fixed-key-2026

# ==================== Redis ====================
# 本地开发模式：docker-compose.yml 将 Redis 映射到宿主机的 16379 端口
# Docker 容器模式：docker-compose.yml 会自动覆盖此配置
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=

# ==================== Worker 配置 ====================
WATCHDOG_INTERVAL_MS=30000
TASK_HEARTBEAT_TIMEOUT_MS=90000
QUEUE_CONCURRENCY_IMAGE=50
QUEUE_CONCURRENCY_VIDEO=50
QUEUE_CONCURRENCY_VOICE=20
QUEUE_CONCURRENCY_TEXT=50

# ==================== AutoDL 自带实例（可选） ====================
# 非商业自部署场景：仅用于连接用户自己的 AutoDL 账号或实例。
# 公共演示站点不要集中收集用户 AutoDL API Key。
AUTODL_OFFICIAL_URL=https://www.autodl.com/home
AUTODL_API_BASE_URL=https://api.autodl.com
# AutoDL 实例会用这个公网地址拉取 Worker bootstrap；部署到服务器时建议设为 https://cryptotools.bar
AUTODL_PUBLIC_SERVER_URL=https://cryptotools.bar
# 仅本地调试时允许把 localhost 写入 AutoDL start_command，默认关闭以免远程实例无法回连
AUTODL_ALLOW_LOCAL_PUBLIC_URL=0

# manual: 用户自行在 AutoDL 官方创建实例，再把 Worker 地址填回平台
# user_api_key: 自部署用户使用自己的 AutoDL API Key 自动创建、查询和释放自己的实例
AUTODL_CONNECTION_MODE=user_api_key
AUTODL_ALLOWED_GPU_PROFILES=pro6000-p,5090-p
AUTODL_DEFAULT_GPU_PROFILE=5090-p
# 默认使用 AutoDL 官方公共基础镜像；有预装模型私有镜像时再覆盖这里。
AUTODL_DEFAULT_IMAGE_UUID=base-image-l2t43iu6uk
AUTODL_DEFAULT_IMAGE_UUID_5090_P=
AUTODL_DEFAULT_IMAGE_UUID_PRO6000_P=
AUTODL_USER_API_KEY=

# 手动连接模式下填写用户自有实例中的 Worker 地址和共享密钥
AUTODL_WORKER_BASE_URL=
AUTODL_WORKER_SHARED_SECRET=

# AutoDL Worker 直接 API 后端（可选）
# 如果不用 ComfyUI，可以让 AutoDL 镜像内已有服务暴露 HTTP API，
# 平台创建实例时会把这些变量注入 start_command，Worker 再把分镜生成请求转发过去。
AUTOGPU_IMAGE_BACKEND=
AUTOGPU_IMAGE_API_URL=
AUTOGPU_IMAGE_API_KEY=
AUTOGPU_IMAGE_HEADERS_JSON=
AUTOGPU_VIDEO_API_URL=
AUTOGPU_VIDEO_API_KEY=
AUTOGPU_VIDEO_HEADERS_JSON=
AUTOGPU_VIDEO_STATUS_API_URL=
AUTOGPU_VIDEO_STATUS_METHOD=GET
AUTOGPU_TTS_API_URL=
AUTOGPU_TTS_API_KEY=
AUTOGPU_TTS_HEADERS_JSON=
AUTOGPU_LLM_API_URL=
AUTOGPU_LLM_API_KEY=
AUTOGPU_LLM_HEADERS_JSON=
AUTOGPU_LLM_TIMEOUT_SECONDS=900

# 内置 Diffusers 文生图后端（可选）
# 设置 AUTOGPU_IMAGE_BACKEND=diffusers 后，Worker 会在 AutoDL 机器里直接加载 Diffusers 模型。
# 首次验证建议选择 sdxl-sd35-medium；如果模型已预置在镜像里，把路径写到 AUTOGPU_IMAGE_DIFFUSERS_MODEL。
AUTOGPU_IMAGE_DIFFUSERS_MODEL=
AUTOGPU_IMAGE_DIFFUSERS_DTYPE=float16
AUTOGPU_IMAGE_DIFFUSERS_LOCAL_FILES_ONLY=
AUTOGPU_IMAGE_DEFAULT_WIDTH=1024
AUTOGPU_IMAGE_DEFAULT_HEIGHT=1024
AUTOGPU_IMAGE_DEFAULT_STEPS=28
AUTOGPU_IMAGE_DEFAULT_GUIDANCE_SCALE=3.5
AUTOGPU_IMAGE_MAX_PIXELS=1048576
AUTOGPU_IMAGE_NEGATIVE_PROMPT=
AUTOGPU_IMAGE_SEED=
AUTOGPU_IMAGE_MODEL_FLUX2_KLEIN_4B=
AUTOGPU_IMAGE_MODEL_QWEN_IMAGE_EDIT=
AUTOGPU_IMAGE_MODEL_SDXL_SD35_MEDIUM=

# 也可以不用 HTTP API，改为在 AutoDL 镜像内放脚本，脚本从 stdin 读 JSON、向 stdout 输出 JSON。
AUTOGPU_SCRIPT_DIR=/root/autogpu-worker/scripts
AUTOGPU_IMAGE_SCRIPT=
AUTOGPU_VIDEO_SCRIPT=
AUTOGPU_TTS_SCRIPT=
AUTOGPU_LLM_SCRIPT=

# ==================== Bull Board (任务管理面板) ====================
BULL_BOARD_HOST=0.0.0.0
BULL_BOARD_PORT=3010
BULL_BOARD_BASE_PATH=/admin/queues
BULL_BOARD_USER=
BULL_BOARD_PASSWORD=

# ==================== 日志 ====================
LOG_UNIFIED_ENABLED=true
LOG_LEVEL=ERROR
LOG_FORMAT=json
LOG_DEBUG_ENABLED=false
LOG_AUDIT_ENABLED=true
LOG_SERVICE=autogpu-studio
LOG_REDACT_KEYS=password,token,apiKey,apikey,authorization,cookie,secret,access_token,refresh_token

# ==================== 计费 ====================
BILLING_MODE=OFF

# ==================== 流式输出 ====================
LLM_STREAM_EPHEMERAL_ENABLED=true
